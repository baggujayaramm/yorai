DATABASE_URL="postgresql://yorai:yorai_password@localhost:5432/yorai_db"
# Public canonical origin. HTTPS is required in production.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Demo identities are local/private-preview only and must be false in production.
YORAI_DEMO_AUTH_ENABLED="true"
# Integer session lifetime in days, from 1 through 365.
YORAI_SESSION_DAYS="30"
# Closed-beta access controls. Comma-separated values may be left blank.
YORAI_BETA_ALLOWED_DOMAINS=""
YORAI_BETA_APPROVED_EMAILS=""
# off, write, or full
YORAI_MAINTENANCE_MODE="off"
# CLOSED_BETA, INVITE_ONLY, LIMITED_PUBLIC, or PUBLIC. Does not enable registration by itself.
YORAI_LAUNCH_MODE="CLOSED_BETA"
# Optional safe release metadata.
NEXT_PUBLIC_APP_VERSION="2.0.0"
YORAI_BUILD_ID="local"
# Feature flags can be overridden with YORAI_FLAG_<UPPERCASE_KEY>=true|false.
# Examples:
# YORAI_FLAG_PUBLIC_REGISTRATION="false"
# YORAI_FLAG_INVITE_ONLY_REGISTRATION="true"
# YORAI_FLAG_APPROVED_DOMAIN_REGISTRATION="false"
# YORAI_FLAG_REGISTRATION_PAUSED="false"
# YORAI_FLAG_PUBLIC_CONTRIBUTIONS="false"
# YORAI_FLAG_READ_ONLY_MODE="false"
# YORAI_FLAG_EMERGENCY_PAUSE_CONTRIBUTIONS="false"
